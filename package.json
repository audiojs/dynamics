{
  "name": "@audio/dynamics",
  "version": "0.2.5",
  "type": "module",
  "types": "index.d.ts",
  "description": "Dynamics processing — umbrella for @audio/dynamics-* atoms (compressor, limiter, gate, expander, de-esser, ducker, softclip, compand, transient shaper)",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "test": "node test.js",
    "test:all": "npm test --workspaces --if-present && npm test",
    "publish:all": "npm publish --workspaces && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/dynamics.git"
  },
  "keywords": [
    "dynamics",
    "compressor",
    "limiter",
    "gate",
    "expander",
    "deesser",
    "ducker",
    "softclip",
    "compand",
    "sidechain",
    "audio",
    "audiojs",
    "dsp"
  ],
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/audiojs/dynamics/issues"
  },
  "homepage": "https://github.com/audiojs/dynamics#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tst": "^9.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "index.js",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@audio/dynamics-envelope": "^0.1.0",
    "@audio/dynamics-compressor": "^0.2.0",
    "@audio/dynamics-limiter": "^0.1.0",
    "@audio/dynamics-gate": "^0.1.0",
    "@audio/dynamics-expander": "^0.2.0",
    "@audio/dynamics-deesser": "^0.2.0",
    "@audio/dynamics-ducker": "^0.1.0",
    "@audio/dynamics-softclip": "^0.2.0",
    "@audio/dynamics-compand": "^0.1.0",
    "@audio/dynamics-transient-shaper": "^0.1.0",
    "@audio/dynamics-multiband": "^0.4.0",
    "@audio/dynamics-opto": "^0.2.0",
    "@audio/dynamics-fet": "^0.2.0",
    "@audio/dynamics-vca": "^0.2.0",
    "@audio/dynamics-varimu": "^0.2.0",
    "@audio/dynamics-leveler": "^0.1.0",
    "@audio/dynamics-unlimit": "^0.1.0"
  },
  "funding": "https://github.com/sponsors/audiojs"
}
