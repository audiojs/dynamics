{
  "name": "@audio/dynamics-fet",
  "version": "0.2.4",
  "description": "FET compressor model — 0.2 ms peak attack, high ratios, firm knee (1176 class)",
  "type": "module",
  "sideEffects": false,
  "main": "fet.js",
  "exports": {
    ".": "./fet.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "fet.js",
    "util.js",
    "audio.js",
    "audio.d.ts",
    "fet.d.ts"
  ],
  "dependencies": {
    "@audio/dynamics-envelope": "^0.1.0",
    "@audio/dynamics-compressor": "^0.2.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "dynamics",
    "compressor",
    "fet"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/dynamics.git",
    "directory": "packages/dynamics-fet"
  },
  "homepage": "https://github.com/audiojs/dynamics/tree/main/packages/dynamics-fet",
  "bugs": {
    "url": "https://github.com/audiojs/dynamics/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./fet.d.ts",
  "audio": "./audio.js",
  "funding": "https://github.com/sponsors/audiojs"
}
