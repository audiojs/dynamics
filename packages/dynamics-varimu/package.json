    },
    "./package.json": "./package.json"
  },
  "files": [
    "varimu.js",
    "util.js",
    "audio.js",
    "audio.d.ts",
    "varimu.d.ts"
  ],
  "dependencies": {
    "@audio/dynamics-envelope": "^0.1.0",
    "@audio/dynamics-compressor": "^0.2.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "dynamics",
    "compressor",
    "varimu"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/dynamics.git",
    "directory": "packages/dynamics-varimu"
  },
  "homepage": "https://github.com/audiojs/dynamics/tree/main/packages/dynamics-varimu",
  "bugs": {
    "url": "https://github.com/audiojs/dynamics/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./varimu.d.ts",
  "audio": "./audio.js",
  "funding": "https://github.com/sponsors/audiojs"
